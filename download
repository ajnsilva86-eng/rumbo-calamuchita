import type { LucideIcon } from "lucide-react";
import { ArrowRight, Users } from "lucide-react";
import Image from "next/image";
import Link from "next/link";

import { WhatsAppButton } from "@/components/WhatsAppButton";
import { getWhatsAppUrl } from "@/data/site";

type CatalogCardProps = {
  href: string;
  name?: string;
  title?: string;
  description: string;
  image: string;
  services: string[];
  whatsappMessage: string;
  capacity?: string;
  icon?: LucideIcon;
};

export function CatalogCard({
  href,
  name,
  title,
  description,
  image,
  services,
  whatsappMessage,
  capacity,
  icon: Icon
}: CatalogCardProps) {
  const itemTitle = name ?? title ?? "Detalle";

  return (
    <article className="overflow-hidden rounded-[8px] border border-forest-900/10 bg-white shadow-soft">
      <Link href={href} className="group block">
        <div className="relative aspect-[4/3] overflow-hidden">
          <Image
            src={image}
            alt={`Foto de ${itemTitle}`}
            fill
            sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
            className="object-cover transition duration-500 group-hover:scale-105"
          />
        </div>
        <div className="p-5 pb-0">
          <div className="flex items-start justify-between gap-4">
            <h3 className="text-xl font-semibold text-forest-900">{itemTitle}</h3>
            <ArrowRight className="mt-1 h-5 w-5 shrink-0 text-forest-700 transition group-hover:translate-x-1" />
          </div>
          <p className="mt-3 line-clamp-3 text-sm leading-6 text-forest-900/70">{description}</p>
          {capacity ? (
            <p className="mt-4 flex items-center gap-2 text-sm font-medium text-earth-700">
              <Users className="h-4 w-4" aria-hidden="true" />
              {capacity}
            </p>
          ) : null}
          {Icon ? (
            <p className="mt-4 flex items-center gap-2 text-sm font-medium text-earth-700">
              <Icon className="h-4 w-4" aria-hidden="true" />
              Ver detalle
            </p>
          ) : null}
        </div>
      </Link>
      <div className="p-5">
        <ul className="grid gap-2 text-sm text-forest-900/70">
          {services.slice(0, 4).map((service) => (
            <li key={service} className="flex gap-2">
              <span className="mt-2 h-1.5 w-1.5 rounded-full bg-forest-600" aria-hidden="true" />
              <span>{service}</span>
            </li>
          ))}
        </ul>
        <WhatsAppButton href={getWhatsAppUrl(whatsappMessage)} className="mt-6 w-full">
          Consultar por WhatsApp
        </WhatsAppButton>
      </div>
    </article>
  );
}
